{
  "version": "0.1",
  "source": "def binary_search(values, target):\n    left = 0\n    right = len(values) - 1\n\n    while left <= right:\n        middle = (left + right) // 2\n\n        if values[middle] == target:\n            return middle\n\n        if values[middle] < target:\n            left = middle + 1\n        else:\n            right = middle - 1\n\n    return -1",
