  "version": "0.1",
  "source": "def fibonacci(n):\n    if n <= 1:\n        return n\n\n    previous = 0\n    current = 1\n\n    for _ in range(2, n + 1):\n        next_value = previous + current\n        previous = current\n        current = next_value\n\n    return current",
