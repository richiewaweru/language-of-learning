{
  "name": "language-of-learning",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:fixtures": "vitest run tests/fixtures",
