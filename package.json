{
  "name": "language-of-learning",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:fixtures": "vitest run tests/fixtures",
    "test:analyzer": "python tools/run_analyzer_tests.py",
    "test:trace": "python tools/run_trace_tests.py",
    "test:variations": "python tools/run_variation_tests.py",
    "test:patterns": "pnpm --filter @lol/lens-patterns test",
    "test:scenes": "pnpm --filter @lol/lens-scenes test",
    "test:journey": "python tools/run_journey_tests.py",
    "test:lessons": "pnpm exec tsx tools/run_lesson_checks.ts",
    "test:api-save": "python tools/run_api_save_tests.py",
    "test:parity-ops": "python tools/run_interpreter_parity.py",
    "test:visual": "vitest run packages/visual-grammar/src",
    "test:web": "vitest run tests/web",
    "capture:pm7": "pnpm exec tsx tools/capture_pm7_screenshots.ts",
    "capture:v1": "pnpm exec tsx tools/capture_v1_screenshots.ts",
    "content:rebuild": "pnpm exec tsx tools/rebuild_content_scenes.ts",
    "test:all": "pnpm test:analyzer && pnpm test:trace && pnpm test:variations && pnpm test:patterns && pnpm test:scenes && pnpm test:fixtures && pnpm test:journey && pnpm test:api-save && pnpm test:lessons && pnpm test:parity-ops && pnpm test:visual && pnpm test:web && pnpm typecheck && pnpm lint",
    "api": "python -m uvicorn apps.api.main:app --reload --host 127.0.0.1 --port 8000",
    "pyodide-parity": "node tools/run_pyodide_parity.mjs",
    "trace-pyodide-parity": "node tools/run_trace_pyodide_parity.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --build",
    "export-schemas": "pnpm --filter @lol/lens-contracts export-schemas"
  },
  "devDependencies": {
    "@lol/lens-contracts": "workspace:*",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "pyodide": "^0.28.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.4"
  }
}
